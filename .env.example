# ---- Database (Neon Postgres, free tier) ----
# Create a project at https://neon.tech, copy the pooled connection string.
DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# ---- Auth (single owner account, no external service) ----
NEXTAUTH_SECRET="generate-with: npx auth secret"
OWNER_EMAIL="you@example.com"
# bcrypt hash, generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
OWNER_PASSWORD_HASH=""

# ---- Cloudflare R2 (large raw documents: pdf/docx/xlsx/md, 50MB+) ----
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# ---- Cloudinary (images/video rendering) ----
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ---- Background jobs (Inngest, free tier) ----
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ---- AI providers (model registry: src/lib/ai/models.ts) ----
# Everything AI-related — the AI Assist panel, translate, summarize, tag
# suggestions — runs through src/lib/ai/tasks.ts, which resolves whichever
# model was requested via src/lib/ai/providers.ts. You only need keys for
# the providers whose models you actually want selectable; missing a key
# just means that provider's models 400 with a clear error until it's set.

# Google AI Studio - free tier, powers the default model (Gemini 2.5 Flash)
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""

# Groq - free tier, ultra-fast Llama/Gemma/Compound models
# https://console.groq.com/keys
GROQ_API_KEY=""

# Anthropic - paid, Claude Sonnet/Opus/Haiku
ANTHROPIC_API_KEY=""

# DeepL - dedicated translation API, optional alternative to LLM translate
DEEPL_API_KEY=""
