# ---- Database (Neon Postgres, free tier) ----
# Create a project at https://neon.tech, copy the pooled connection string.
DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# ---- Auth (single owner account, no external service) ----
NEXTAUTH_SECRET="generate-with: npx auth secret"
OWNER_EMAIL="you@example.com"
# bcrypt hash, generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
OWNER_PASSWORD_HASH=""

# ---- Cloudflare R2 (large raw documents: pdf/docx/xlsx/md, 50MB+) ----
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# ---- Cloudinary (images/video rendering) ----
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ---- Background jobs (Inngest, free tier) ----
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ---- AI providers (task registry, PLAN.md §6) ----
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
DEEPL_API_KEY=""
